{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "noEmit": false,
    "lib": [
      "ESNext"
    ],
    "types": [
      "node",
      "jest"
    ],
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "**/*.ts",
    "./release.config.mjs"
  ]
}
